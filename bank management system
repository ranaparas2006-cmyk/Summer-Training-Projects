class Bank:
    def __init__(self):
        self.balance = 0

    def deposit(self):
        amount = int(input("Enter amount to deposit: "))
        self.balance += amount
        print("Deposited successfully")

    def withdraw(self):
        amount = int(input("Enter amount to withdraw: "))
        if amount <= self.balance:
            self.balance -= amount
            print("Withdraw successful")
        else:
            print("Not enough balance")

    def show_balance(self):
        print("Current balance:", self.balance)


# object create
b = Bank()

while True:
  
    print("1. Deposit")
    print("2. Withdraw")
    print("3. Balance")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        b.deposit()
    elif choice == "2":
        b.withdraw()
    elif choice == "3":
        b.show_balance()
    elif choice == "4":
        print("Thank you")
        break
    else:
        print("Invalid choice")
