text = input("Enter a passage: ")

words = text.lower().split()

freq = {}

for word in words:
    freq[word] = freq.get(word, 0) + 1
sorted_words = sorted(freq.items(), key=lambda x: x[1], reverse=True)

print("Top 5 Most Frequent Words:")

for word, count in sorted_words[:5]:
    print(word, ":", count)
