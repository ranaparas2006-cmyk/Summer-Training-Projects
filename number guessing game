

secret_number = 25
attempts = 0

print("Welcome to Number Guessing Game!")
print("Guess the number between 1 and 50")

while True:
    guess = int(input("Enter your guess: "))
    attempts = attempts + 1

    if guess > secret_number:
        print("Too High")
    elif guess < secret_number:
        print("Too Low")
    else:
        print("Correct Guess!")
        print("Number of attempts =", attempts)
        break
