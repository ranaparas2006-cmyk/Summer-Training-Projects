contacts = {}
numbers = set()

while True:
    print("1.Add 2.Search 3.Delete 4.Exit")
    choice = input("Enter choice: ")

    if choice == "1":
        name = input("Name: ")
        num = input("Number: ")

        if num in numbers:
            print("Duplicate Number!")
        else:
            contacts[name] = num
            numbers.add(num)
            print("Contact Added")

    elif choice == "2":
        name = input("Search Name: ")

        if name in contacts:
            print("Number:", contacts[name])
        else:
            print("Not Found")

    elif choice == "3":
        name = input("Delete Name: ")

        if name in contacts:
            numbers.remove(contacts[name])
            del contacts[name]
            print("Contact Deleted")
        else:
            print("Not Found")

    elif choice == "4":
        print("Exit")
        break

    else:
        print("Invalid Choice")
